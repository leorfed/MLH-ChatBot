DJANGO_SECRET_KEY=change-this-to-a-long-random-string
ENVIRONMENT=development
AGENT_SECRET=change-this-too

# Optional — leave unset for SQLite + in-memory Channels (local dev defaults)
# DATABASE_URL=postgresql://user:pass@localhost:5432/dating_site
# REDIS_URL=redis://localhost:6379/0

# Optional — restrict CORS in production
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Auth0 (optional for OAuth login)
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
